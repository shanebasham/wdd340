<h1><%= title %></h1>

<!-- Flash Message -->
<!-- <div class="flash-message">
    %- flash_message %>
</div> -->

<!-- Login Form -->
<form id="loginForm" action="/account/login" method="post">
    <div class="form-group">
        <label for="email">Email Address:</label>
        <input type="email" id="accountEmail" name="account_email" value="<%= locals.account_email %>" required>
    </div>
    <div class="form-group">
        <label for="password">Password:</label>
        <!-- <span>Passwords must be at least 12 characters and contain at least 1 number, 1 capital letter and 1 special character</span> -->
        <input type="password" id="account_password" name="account_password" pattern="^(?=.*\d)(?=.*[a-z])(?=.*[A-Z])(?=.*[^a-zA-Z0-9])(?!.*\s).{12,}$" required> 
    </div>
    <button type="submit">Login</button>
</form>

<!-- Registration Link -->
<p class="register-link">No account? <a href="/account/register">Register here</a>.</p>
