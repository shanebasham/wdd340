<!-- Add classification view form -->
<form id="addNewClassification" action="/inv/add-classification" method="post">
    <div class="form-group">
        <label for="name">Enter Classification Name:</label>
        <input type="text" id="classificationName" name="classificationName" pattern="/^[a-zA-Z0-9]+$/" required>
    </div>
    <button type="submit">ADD</button>
</form>




