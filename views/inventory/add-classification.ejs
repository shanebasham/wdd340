<!-- view -->
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Add Classification</title>
    <script>
        function validateForm() {
            const classificationName = document.getElementById('classificationName').value;
            const regex = /^[a-zA-Z0-9]+$/; // Allow only alphanumeric characters
            if (!regex.test(classificationName)) {
                alert("Classification name cannot contain spaces or special characters.");
                return false;
            }
            return true;
        }
    </script>
</head>
<body>
    <h1>Add New Classification</h1>
    <form id="addClassificationForm" action="/classifications/add" method="POST" onsubmit="return validateForm()">
        <label for="classificationName">Classification Name:</label>
        <input type="text" id="classificationName" name="classificationName" required>
        <button type="submit">Add Classification</button>
    </form>
    <% if (flashMessage) { %>
        <div class="flash-message"><%= flashMessage %></div>
    <% } %>
    <% if (errors && errors.length > 0) { %>
        <div class="error-messages">
            <% errors.forEach(error => { %>
                <p><%= error %></p>
            <% }); %>
        </div>
    <% } %>
</body>
</html>

